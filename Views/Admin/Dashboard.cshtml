@model IEnumerable<CodeAlpha_EcommerceStore.Models.Product>
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid py-4">
    <!-- Header Section -->
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h2 class="fw-bold m-0 text-primary">Dashboard Overview</h2>
            <p class="text-muted">Welcome back! Here is what's happening with your store today.</p>
        </div>
        <div class="col-auto text-end">
             <span class="badge bg-primary-soft text-primary p-2 border border-primary">@DateTime.Now.ToString("D")</span>
        </div>
    </div>

    <!-- Stats Cards Row -->
    <div class="row g-4 mb-4">
        <!-- Revenue Card -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 border-start border-primary border-5 h-100">
                <div class="d-flex align-items-center gap-3">
                    <div class="p-3 rounded-3 bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-currency-dollar fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small mb-0 fw-bold">TOTAL REVENUE</h6>
                        <h4 class="fw-bold mb-0">Rs. @ViewBag.TotalRevenue.ToString("N0")</h4>
                    </div>
                </div>
            </div>
        </div>
        <!-- Products Card -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 border-start border-success border-5 h-100">
                <div class="d-flex align-items-center gap-3">
                    <div class="p-3 rounded-3 bg-success bg-opacity-10 text-success">
                        <i class="bi bi-box-seam fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small mb-0 fw-bold">TOTAL PRODUCTS</h6>
                        <h4 class="fw-bold mb-0">@ViewBag.TotalProducts</h4>
                    </div>
                </div>
            </div>
        </div>
        <!-- Orders Card -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 border-start border-info border-5 h-100">
                <div class="d-flex align-items-center gap-3">
                    <div class="p-3 rounded-3 bg-info bg-opacity-10 text-info">
                        <i class="bi bi-cart-check fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small mb-0 fw-bold">TOTAL ORDERS</h6>
                        <h4 class="fw-bold mb-0">@ViewBag.TotalOrders</h4>
                    </div>
                </div>
            </div>
        </div>
        <!-- Low Stock Card -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 p-3 border-start border-danger border-5 h-100">
                <div class="d-flex align-items-center gap-3">
                    <div class="p-3 rounded-3 bg-danger bg-opacity-10 text-danger">
                        <i class="bi bi-exclamation-triangle fs-3"></i>
                    </div>
                    <div>
                        <h6 class="text-muted small mb-0 fw-bold">LOW STOCK</h6>
                        <h4 class="fw-bold mb-0">@ViewBag.LowStock</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Chart Section -->
    <div class="row mb-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <h5 class="fw-bold mb-4">Sales & Revenue Performance</h5>
                <canvas id="revenueChart" style="max-height: 300px;"></canvas>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <h5 class="fw-bold mb-4">Inventory Status</h5>
                <canvas id="inventoryChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Recent Products Table Card -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
        <div class="card-header bg-white border-0 p-4">
            <h5 class="fw-bold m-0">Recently Added Products</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 border-0">Product Details</th>
                        <th class="py-3 border-0 text-center">Category</th>
                        <th class="py-3 border-0 text-center">Price</th>
                        <th class="py-3 border-0 text-center">Stock</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@item.ImageUrl" class="rounded-3 shadow-sm" width="45" height="45" style="object-fit: cover;" onerror="this.src='https://placehold.co/50x50?text=No+Image'">
                                    <div>
                                        <div class="fw-bold">@item.ProductName</div>
                                        <div class="small text-muted">ID: #@item.ProductId</div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border px-2 py-1">@item.Category?.CategoryName</span>
                            </td>
                            <td class="fw-bold text-center">
                                Rs. @item.Price.ToString("N0")
                            </td>
                            <td class="text-center">
                                @if (item.StockQuantity > 10)
                                {
                                    <span class="badge rounded-pill bg-success bg-opacity-10 text-success px-3">@item.StockQuantity In Stock</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger px-3">@item.StockQuantity Low Stock</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- SCRIPTS FOR CHARTS -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Revenue Line Chart
    const revCtx = document.getElementById('revenueChart').getContext('2d');
    new Chart(revCtx, {
        type: 'line',
        data: {
            labels: @Html.Raw(Json.Serialize(ViewBag.ChartLabels)),
            datasets: [{
                label: 'Monthly Revenue (Rs)',
                data: @Html.Raw(Json.Serialize(ViewBag.ChartData)),
                borderColor: '#4e73df',
                backgroundColor: 'rgba(78, 115, 223, 0.1)',
                fill: true,
                tension: 0.4,
                pointRadius: 5
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true, grid: { drawBorder: false } } }
        }
    });

    // Inventory Doughnut Chart
    const invCtx = document.getElementById('inventoryChart').getContext('2d');
    new Chart(invCtx, {
        type: 'doughnut',
        data: {
            labels: ['In Stock', 'Low Stock'],
            datasets: [{
                data: [@ViewBag.TotalProducts, @ViewBag.LowStock],
                backgroundColor: ['#1cc88a', '#e74a3b'],
                hoverOffset: 4
            }]
        },
        options: {
            cutout: '70%',
            plugins: { legend: { position: 'bottom' } }
        }
    });
</script>

<style>
    :root {
        --primary: #4e73df;
        --success: #1cc88a;
        --info: #36b9cc;
        --danger: #e74a3b;
    }
    .bg-primary-soft { background-color: rgba(78, 115, 223, 0.05); }
    .table thead th { font-size: 0.8rem; letter-spacing: 0.5px; color: #5a5c69; }
    .card { transition: transform 0.2s; }
    .card:hover { transform: translateY(-3px); }
</style>