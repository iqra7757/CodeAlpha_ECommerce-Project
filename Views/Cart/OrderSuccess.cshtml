@{
    ViewData["Title"] = "Order Success";
}

<div class="container mt-5 py-5 text-center">
    <div class="card border-0 shadow-sm rounded-4 p-5 mx-auto" style="max-width: 600px;">
        <div class="mb-4">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
        </div>
        <h1 class="fw-bold">Order Confirmed!</h1>
        <p class="text-muted fs-5">Thank you for your purchase. Your order is being processed.</p>
        
        <div class="bg-light p-3 rounded-3 my-4 border">
            <small class="text-muted d-block">Order Reference</small>
            <span class="fw-bold text-primary">#@Guid.NewGuid().ToString().Substring(0, 8).ToUpper()</span>
        </div>

        <div class="d-grid gap-2">
            <a asp-controller="Products" asp-action="Index" class="btn btn-primary rounded-pill py-3 fw-bold shadow">
                Continue Shopping
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-link text-muted">Back to Home</a>
        </div>
    </div>
</div>