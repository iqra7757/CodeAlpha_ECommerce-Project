@model IEnumerable<CodeAlpha_EcommerceStore.Models.CartItem>
@{
    ViewData["Title"] = "Your Shopping Cart";
    decimal grandTotal = 0;
}

<div class="container mt-5">
    <div class="mb-4">
        <h2 class="fw-800 m-0 text-accent">Shopping Cart</h2>
        <p class="text-muted">Review your items before proceeding to checkout.</p>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 p-5 text-center" style="background: var(--card); border: 1px solid var(--border) !important;">
            <div class="mb-3">
                <i class="bi bi-cart-x text-muted" style="font-size: 4rem;"></i>
            </div>
            <h4 class="fw-bold">Your cart is empty</h4>
            <p class="text-muted">Looks like you haven't added anything to your cart yet.</p>
            <div class="mt-3">
                <a asp-controller="Products" asp-action="Index" class="btn btn-primary rounded-pill px-4 fw-bold">
                    <i class="bi bi-arrow-left me-2"></i>Back to Shop
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden" style="background: var(--card); border: 1px solid var(--border) !important;">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 border-0">Product</th>
                                    <th class="py-3 border-0 text-center">Price</th>
                                    <th class="py-3 border-0 text-center">Quantity</th>
                                    <th class="py-3 border-0 text-center">Total</th>
                                    <th class="py-3 border-0 text-end pe-4">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    var itemTotal = (item.Product?.Price ?? 0) * item.Quantity;
                                    grandTotal += itemTotal;

                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center gap-3">
                                                <img src="@(string.IsNullOrEmpty(item.Product?.ImageUrl) ? "https://placehold.co/45x45?text=No+Image" : item.Product.ImageUrl)" 
                                                     class="rounded-3 shadow-sm" width="55" height="55" style="object-fit: cover;">
                                                <div>
                                                    <div class="fw-bold">@item.Product?.ProductName</div>
                                                    <div class="text-muted small">@item.Product?.Category?.CategoryName</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">Rs. @item.Product?.Price.ToString("N0")</td>
                                        <td class="text-center">
                                            <span class="badge bg-light text-dark border px-3 py-2 rounded-3">
                                                @item.Quantity
                                            </span>
                                        </td>
                                        <td class="text-center fw-bold text-accent">Rs. @itemTotal.ToString("N0")</td>
                                        <td class="text-end pe-4">
                                            <form asp-action="Remove" asp-route-id="@item.CartItemId" method="post" onsubmit="return confirm('Remove this item?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle shadow-sm">
                                                    <i class="bi bi-trash3"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                
                <div class="mt-3">
                    <a asp-controller="Products" asp-action="Index" class="text-accent fw-bold text-decoration-none">
                        <i class="bi bi-arrow-left me-1"></i> Continue Shopping
                    </a>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 sticky-top" style="top: 90px; background: var(--card); border: 1px solid var(--border) !important;">
                    <h5 class="fw-bold mb-4">Order Summary</h5>
                    
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Subtotal</span>
                        <span>Rs. @grandTotal.ToString("N0")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Shipping</span>
                        <span class="text-success fw-bold">FREE</span>
                    </div>
                    
                    <hr class="my-3" style="border-top: 1px dashed var(--border);">
                    
                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-bold fs-5">Total</span>
                        <span class="fw-bold fs-5 text-accent">Rs. @grandTotal.ToString("N0")</span>
                    </div>

                    <div class="d-grid gap-2">
                        <!-- FIX: Changed button to <a> tag with Controller/Action -->
                        <a asp-controller="Cart" asp-action="Checkout" class="btn btn-primary rounded-pill py-3 fw-bold shadow text-white">
                            Proceed to Checkout <i class="bi bi-credit-card ms-2"></i>
                        </a>
                    </div>

                    <div class="mt-4 text-center">
                        <p class="small text-muted mb-0"><i class="bi bi-shield-check me-1"></i> Secure Checkout Guaranteed</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    :root { --accent: #4e73df; --border: #e3e6f0; --card: #ffffff; }
    .text-accent { color: var(--accent) !important; }
    .fw-800 { font-weight: 800; }
    .btn-primary { background: var(--accent); border: none; }
    .btn-primary:hover { filter: brightness(0.9); color: white; }
    .table th { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; }
</style>